        </div>
        <span class="footer-logo-text">ClientForge</span>
    </a>
    <p class="footer-desc">Project and client management — simple, beautiful and effective.</p>
    <div class="footer-links">
        <a href="/"><i class="fa-solid fa-house" style="margin-right:4px"></i> Home</a>
        <a href="/Projects"><i class="fa-solid fa-folder-open" style="margin-right:4px"></i> Projects</a>
        <a href="/Welcome"><i class="fa-solid fa-globe" style="margin-right:4px"></i> Platform</a>
        <a href="/Authentication"><i class="fa-solid fa-right-to-bracket" style="margin-right:4px"></i> Login</a>
    </div>
