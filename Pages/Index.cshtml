@page
@model IndexModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ClientForge — Home</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        html { scroll-behavior: smooth; }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
            color: #fff;
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
        }

        /* ── Orbs ── */
        .orb { position: fixed; border-radius: 50%; filter: blur(100px); opacity: .3; pointer-events: none; z-index: 0; }
        .orb-1 { width: 500px; height: 500px; background: #6c63ff; top: -120px; left: -120px; animation: oF1 10s ease-in-out infinite; }
        .orb-2 { width: 400px; height: 400px; background: #ff6584; bottom: -100px; right: -100px; animation: oF2 12s ease-in-out infinite; }
        .orb-3 { width: 300px; height: 300px; background: #43e97b; top: 50%; left: 60%; animation: oF3 14s ease-in-out infinite; }
        @@keyframes oF1 { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(40px,30px) scale(1.08)} }
        @@keyframes oF2 { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(-30px,-40px) scale(1.06)} }
        @@keyframes oF3 { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(-50px,20px) scale(1.1)} }

        /* ── Header ── */
        .header {
            position: fixed; top: 0; left: 0; right: 0; z-index: 100;
            padding: 0 40px; height: 72px;
            display: flex; align-items: center; justify-content: space-between;
            background: rgba(15,12,41,.6);
            backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255,255,255,.08);
            transition: background .3s;
        }
        .header.scrolled { background: rgba(15,12,41,.9); }

        .header-logo { display: flex; align-items: center; gap: 12px; text-decoration: none; }
        .header-logo-icon {
            width: 38px; height: 38px;
            background: linear-gradient(135deg, #6c63ff, #ff6584);
            border-radius: 10px; display: flex; align-items: center; justify-content: center;
            box-shadow: 0 4px 16px rgba(108,99,255,.3);
        }
        .header-logo-icon i { font-size: 18px; color: #fff; }
        .header-logo-text { font-size: 20px; font-weight: 700; color: #fff; letter-spacing: -.3px; }

        .header-nav { display: flex; align-items: center; gap: 8px; }
        .header-nav a {
            color: rgba(255,255,255,.6); text-decoration: none;
            font-size: 14px; font-weight: 500; padding: 8px 16px;
            border-radius: 10px; transition: all .25s ease;
        }
        .header-nav a:hover { color: #fff; background: rgba(255,255,255,.08); }
        .header-nav a.active { color: #fff; background: rgba(108,99,255,.2); }

        .header-right { display: flex; align-items: center; gap: 12px; }

        .btn-ghost {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 10px 22px; border: 1px solid rgba(255,255,255,.2);
            border-radius: 12px; background: transparent; color: #fff;
            font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 500;
            cursor: pointer; text-decoration: none; transition: all .3s ease;
        }
        .btn-ghost:hover { border-color: rgba(255,255,255,.4); background: rgba(255,255,255,.06); }

        .btn-primary-sm {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 10px 22px; border: none; border-radius: 12px;
            background: linear-gradient(135deg, #6c63ff, #7c5cfc);
            color: #fff; font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600;
            cursor: pointer; text-decoration: none; transition: all .3s ease;
            box-shadow: 0 4px 16px rgba(108,99,255,.3);
        }
        .btn-primary-sm:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(108,99,255,.45); }

        .user-pill {
            display: flex; align-items: center; gap: 8px;
            padding: 6px 16px 6px 8px;
            background: rgba(255,255,255,.08);
            border: 1px solid rgba(255,255,255,.1);
            border-radius: 50px; font-size: 13px; font-weight: 500;
            color: rgba(255,255,255,.8); text-decoration: none;
            transition: all .25s;
        }
        .user-pill:hover { background: rgba(255,255,255,.12); }
        .user-avatar {
            width: 28px; height: 28px; border-radius: 50%;
            background: linear-gradient(135deg, #6c63ff, #ff6584);
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; font-weight: 700; color: #fff;
        }

        .hamburger { display: none; background: none; border: none; color: #fff; font-size: 22px; cursor: pointer; padding: 8px; }

        /* ── Content ── */
        .content { position: relative; z-index: 1; }

        /* ── Hero ── */
        .hero {
            min-height: 70vh; display: flex; align-items: center; justify-content: center;
            text-align: center; padding: 120px 24px 60px;
        }
        .hero-inner { max-width: 680px; }
        .hero-badge {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 8px 18px; background: rgba(108,99,255,.15);
            border: 1px solid rgba(108,99,255,.3); border-radius: 50px;
            color: #a8a3ff; font-size: 13px; font-weight: 500; margin-bottom: 28px;
            animation: fadeUp .6s ease forwards;
        }
        .hero h1 {
            font-size: 52px; font-weight: 800; line-height: 1.1;
            letter-spacing: -1.5px; margin-bottom: 20px;
            animation: fadeUp .6s ease .15s both;
        }
        .hero h1 .gradient-text {
            background: linear-gradient(135deg, #6c63ff, #ff6584);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .hero-sub {
            font-size: 17px; line-height: 1.7; color: rgba(255,255,255,.5);
            max-width: 540px; margin: 0 auto 36px;
            animation: fadeUp .6s ease .3s both;
        }
        .hero-buttons {
            display: flex; align-items: center; justify-content: center; gap: 16px;
            animation: fadeUp .6s ease .45s both;
        }
        .btn-hero {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 16px 36px; border: none; border-radius: 14px;
            background: linear-gradient(135deg, #6c63ff, #7c5cfc);
            color: #fff; font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 600;
            cursor: pointer; text-decoration: none; transition: all .3s ease;
            box-shadow: 0 8px 32px rgba(108,99,255,.35); position: relative; overflow: hidden;
        }
        .btn-hero::before {
            content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,.15), transparent);
            transition: left .5s ease;
        }
        .btn-hero:hover { transform: translateY(-3px); box-shadow: 0 12px 40px rgba(108,99,255,.5); }
        .btn-hero:hover::before { left: 100%; }
        .btn-hero-outline {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 16px 36px; border: 1px solid rgba(255,255,255,.2);
            border-radius: 14px; background: rgba(255,255,255,.05);
            color: #fff; font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 500;
            cursor: pointer; text-decoration: none; transition: all .3s ease;
        }
        .btn-hero-outline:hover { border-color: rgba(255,255,255,.4); background: rgba(255,255,255,.1); transform: translateY(-2px); }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(24px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* ── Quick Actions ── */
        .quick-actions {
            padding: 0 24px 80px;
            max-width: 1100px; margin: 0 auto;
        }
        .section-header { text-align: center; margin-bottom: 48px; }
        .section-header h2 { font-size: 32px; font-weight: 700; letter-spacing: -.8px; margin-bottom: 12px; }
        .section-header p { font-size: 15px; color: rgba(255,255,255,.45); max-width: 460px; margin: 0 auto; line-height: 1.6; }

        .actions-grid {
            display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
        }
        .action-card {
            background: rgba(255,255,255,.06);
            backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,.1); border-radius: 20px;
            padding: 36px 28px; text-decoration: none; color: #fff;
            transition: all .35s ease; position: relative; overflow: hidden;
        }
        .action-card:hover { transform: translateY(-6px); border-color: rgba(108,99,255,.3); box-shadow: 0 16px 48px rgba(0,0,0,.2); }
        .action-card:hover .action-arrow { opacity: 1; transform: translateX(0); }

        .action-icon {
            width: 52px; height: 52px; border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            margin-bottom: 20px; font-size: 22px;
        }
        .action-icon.purple { background: rgba(108,99,255,.15); color: #6c63ff; }
        .action-icon.pink { background: rgba(255,101,132,.15); color: #ff6584; }
        .action-icon.green { background: rgba(67,233,123,.15); color: #43e97b; }
        .action-icon.blue { background: rgba(56,189,248,.15); color: #38bdf8; }
        .action-icon.orange { background: rgba(251,146,60,.15); color: #fb923c; }
        .action-icon.cyan { background: rgba(34,211,238,.15); color: #22d3ee; }

        .action-card h3 { font-size: 18px; font-weight: 600; margin-bottom: 10px; letter-spacing: -.2px; }
        .action-card p { font-size: 14px; line-height: 1.65; color: rgba(255,255,255,.45); margin: 0; }
        .action-arrow {
            position: absolute; top: 28px; right: 24px;
            opacity: 0; transform: translateX(-8px);
            transition: all .3s ease; color: rgba(255,255,255,.3); font-size: 16px;
        }

        /* ── Stats ── */
        .stats-section {
            padding: 0 24px 80px;
            max-width: 900px; margin: 0 auto;
        }
        .stats-card {
            background: rgba(255,255,255,.06);
            backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,.1); border-radius: 24px;
            padding: 48px 40px; text-align: center;
        }
        .stats-card h2 { font-size: 28px; font-weight: 700; margin-bottom: 8px; letter-spacing: -.5px; }
        .stats-card > p { font-size: 15px; color: rgba(255,255,255,.45); margin-bottom: 36px; }
        .stats-grid { display: flex; justify-content: center; gap: 48px; flex-wrap: wrap; }
        .stat { text-align: center; }
        .stat-number {
            font-size: 40px; font-weight: 700;
            background: linear-gradient(135deg, #6c63ff, #ff6584);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .stat-label { font-size: 13px; color: rgba(255,255,255,.4); margin-top: 4px; font-weight: 500; }

        /* ── How It Works ── */
        .how-section {
            padding: 0 24px 80px;
            max-width: 1100px; margin: 0 auto;
        }
        .steps-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
        .step-card {
            text-align: center; padding: 32px 20px;
            background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.06);
            border-radius: 20px; transition: all .35s ease; position: relative;
        }
        .step-card:hover { background: rgba(255,255,255,.07); border-color: rgba(255,255,255,.12); transform: translateY(-4px); }
        .step-number {
            width: 40px; height: 40px; border-radius: 50%;
            background: linear-gradient(135deg, #6c63ff, #ff6584);
            display: inline-flex; align-items: center; justify-content: center;
            font-size: 16px; font-weight: 700; margin-bottom: 16px;
        }
        .step-card h4 { font-size: 16px; font-weight: 600; margin-bottom: 8px; }
        .step-card p { font-size: 13px; color: rgba(255,255,255,.4); line-height: 1.6; }

        /* ── CTA ── */
        .cta-section { padding: 0 24px 80px; text-align: center; }
        .cta-card {
            max-width: 700px; margin: 0 auto;
            background: linear-gradient(135deg, rgba(108,99,255,.2), rgba(255,101,132,.15));
            backdrop-filter: blur(20px); border: 1px solid rgba(108,99,255,.25);
            border-radius: 24px; padding: 56px 48px;
        }
        .cta-card h2 { font-size: 32px; font-weight: 700; margin-bottom: 16px; letter-spacing: -.5px; }
        .cta-card p { font-size: 16px; color: rgba(255,255,255,.55); margin-bottom: 36px; line-height: 1.6; }
        .cta-buttons { display: flex; align-items: center; justify-content: center; gap: 16px; }

        /* ── Footer ── */
        .footer {
            position: relative; z-index: 1; margin-top: 0;
            border-top: 1px solid rgba(255,255,255,.06);
            padding: 48px 40px 36px;
            display: flex; flex-direction: column; align-items: center;
            text-align: center; gap: 20px;
        }
        .footer-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; margin-bottom: 4px; }
        .footer-logo-icon {
            width: 32px; height: 32px;
            background: linear-gradient(135deg, #6c63ff, #ff6584);
            border-radius: 8px; display: flex; align-items: center; justify-content: center;
        }
        .footer-logo-icon i { font-size: 14px; color: #fff; }
        .footer-logo-text { font-size: 16px; font-weight: 700; color: rgba(255,255,255,.7); letter-spacing: -.3px; }
        .footer-desc { color: rgba(255,255,255,.3); font-size: 13px; max-width: 400px; line-height: 1.6; }
        .footer-links { display: flex; align-items: center; gap: 24px; }
        .footer-links a {
            color: rgba(255,255,255,.35); text-decoration: none;
            font-size: 13px; font-weight: 500; transition: color .25s;
        }
        .footer-links a:hover { color: #6c63ff; }
        .footer-divider { width: 100%; max-width: 500px; height: 1px; background: rgba(255,255,255,.06); }
        .footer-copy { color: rgba(255,255,255,.2); font-size: 12px; }

        /* ── Responsive ── */
        @@media (max-width: 900px) {
            .actions-grid { grid-template-columns: repeat(2, 1fr); }
            .steps-grid { grid-template-columns: repeat(2, 1fr); }
        }

        @@media (max-width: 768px) {
            .header { padding: 0 20px; }
            .header-nav {
                display: none; position: absolute; top: 72px; left: 0; right: 0;
                flex-direction: column; background: rgba(15,12,41,.95);
                backdrop-filter: blur(20px); padding: 16px;
                border-bottom: 1px solid rgba(255,255,255,.08); gap: 4px;
            }
            .header-nav.open { display: flex; }
            .header-nav a { padding: 12px 16px; }
            .hamburger { display: block; }
            .header-right { display: none; }

            .hero h1 { font-size: 34px; }
            .hero-sub { font-size: 15px; }
            .hero-buttons { flex-direction: column; }
            .btn-hero, .btn-hero-outline { width: 100%; justify-content: center; }

            .actions-grid { grid-template-columns: 1fr; }
            .steps-grid { grid-template-columns: 1fr; }

            .stats-card { padding: 36px 24px; }
            .stats-grid { gap: 28px; }

            .cta-card { padding: 36px 24px; }
            .cta-buttons { flex-direction: column; }

            .footer { padding: 36px 20px 28px; }
            .footer-links { flex-wrap: wrap; justify-content: center; gap: 16px; }
        }
    </style>
</head>
<body>

<!-- Background orbs -->
<div class="orb orb-1"></div>
<div class="orb orb-2"></div>
<div class="orb orb-3"></div>

<!-- ════════════ Header ════════════ -->
<header class="header" id="header">
    <a class="header-logo" href="/">
        <div class="header-logo-icon">
            <i class="fa-solid fa-hammer"></i>
        </div>
        <span class="header-logo-text">ClientForge</span>
    </a>

    <nav class="header-nav" id="nav">
        <a href="/Projects"><i class="fa-solid fa-folder-open" style="margin-right:4px"></i> Projects</a>
        <a href="/Welcome"><i class="fa-solid fa-globe" style="margin-right:4px"></i> Platform</a>
    </nav>

    <div class="header-right">
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            var firstName = (User.FindFirst(System.Security.Claims.ClaimTypes.GivenName) ?? User.FindFirst("given_name"))?.Value ?? "";
            var surname = (User.FindFirst(System.Security.Claims.ClaimTypes.Surname) ?? User.FindFirst("family_name"))?.Value ?? "";
            var initials = "";
            if (firstName.Length > 0) initials += firstName[0];
            if (surname.Length > 0) initials += surname[0];
            <span class="user-pill">
                <span class="user-avatar">@initials</span>
                @firstName @surname
            </span>
            <a class="btn-ghost" asp-page="/Pages/Authentication" asp-page-handler="Logout">
                <i class="fa-solid fa-right-from-bracket"></i> Logout
            </a>
        }
        else
        {
            <a class="btn-ghost" asp-page="/Pages/Authentication">
                <i class="fa-solid fa-right-to-bracket"></i> Login
            </a>
            <a class="btn-primary-sm" asp-page="/Pages/Authentication">
                <i class="fa-solid fa-user-plus"></i> Sign Up
            </a>
        }
    </div>

    <button class="hamburger" id="hamburgerBtn" aria-label="Toggle menu">
        <i class="fa-solid fa-bars"></i>
    </button>
</header>

<div class="content">

    <!-- ════════════ Hero ════════════ -->
    <section class="hero">
        <div class="hero-inner">
            <div class="hero-badge">
                <i class="fa-solid fa-sparkles"></i>
                Control Panel
            </div>
            <h1>Welcome to <span class="gradient-text">ClientForge</span></h1>
            <p class="hero-sub">
                Your unified workspace for managing projects, tasks and clients.
                Start working right away.
            </p>
            <div class="hero-buttons">
                <a class="btn-hero" href="/Projects">
                    <i class="fa-solid fa-rocket"></i> My Projects
                </a>
                <a class="btn-hero-outline" href="/Welcome">
                    <i class="fa-solid fa-play"></i> About Platform
                </a>
            </div>
        </div>
    </section>

    <!-- ════════════ Quick Actions ════════════ -->
    <section class="quick-actions">
        <div class="section-header">
            <h2>Quick Actions</h2>
            <p>Go to the section you need with one click.</p>
        </div>
        <div class="actions-grid">
            <a class="action-card" href="/Projects">
                <span class="action-arrow"><i class="fa-solid fa-arrow-right"></i></span>
                <div class="action-icon purple">
                    <i class="fa-solid fa-diagram-project"></i>
                </div>
                <h3>Projects</h3>
                <p>View all your projects, track statuses and monitor deadlines.</p>
            </a>
            <a class="action-card" href="/Projects">
                <span class="action-arrow"><i class="fa-solid fa-arrow-right"></i></span>
                <div class="action-icon pink">
                    <i class="fa-solid fa-list-check"></i>
                </div>
                <h3>Tasks</h3>
                <p>Manage tasks, assign workers and track execution progress.</p>
            </a>
            <a class="action-card" href="/Projects">
                <span class="action-arrow"><i class="fa-solid fa-arrow-right"></i></span>
                <div class="action-icon green">
                    <i class="fa-solid fa-users"></i>
                </div>
                <h3>Clients</h3>
                <p>Maintain a client database, assign projects and support communication.</p>
            </a>
            <a class="action-card" href="/Projects">
                <span class="action-arrow"><i class="fa-solid fa-arrow-right"></i></span>
                <div class="action-icon blue">
                    <i class="fa-solid fa-chart-line"></i>
                </div>
                <h3>Analytics</h3>
                <p>Get reports on team performance and project statuses.</p>
            </a>
            <a class="action-card" href="/Projects">
                <span class="action-arrow"><i class="fa-solid fa-arrow-right"></i></span>
                <div class="action-icon orange">
                    <i class="fa-solid fa-shield-halved"></i>
                </div>
                <h3>Security</h3>
                <p>JWT authentication, data encryption and role-based access — your data is protected.</p>
            </a>
            <a class="action-card" href="/Welcome">
                <span class="action-arrow"><i class="fa-solid fa-arrow-right"></i></span>
                <div class="action-icon cyan">
                    <i class="fa-solid fa-bolt"></i>
                </div>
                <h3>Performance</h3>
                <p>Lightning-fast performance thanks to modern technologies and optimization.</p>
            </a>
        </div>
    </section>

    <!-- ════════════ Stats ════════════ -->
    <section class="stats-section">
        <div class="stats-card">
            <h2>ClientForge by Numbers</h2>
            <p>A platform trusted by thousands of teams around the world.</p>
            <div class="stats-grid">
                <div class="stat">
                    <div class="stat-number">10k+</div>
                    <div class="stat-label">Projects Created</div>
                </div>
                <div class="stat">
                    <div class="stat-number">5k+</div>
                    <div class="stat-label">Users</div>
                </div>
                <div class="stat">
                    <div class="stat-number">99.9%</div>
                    <div class="stat-label">Uptime</div>
                </div>
                <div class="stat">
                    <div class="stat-number">24/7</div>
                    <div class="stat-label">Support</div>
                </div>
            </div>
        </div>
    </section>

    <!-- ════════════ How It Works ════════════ -->
    <section class="how-section">
        <div class="section-header">
            <h2>How It Works</h2>
            <p>Four simple steps to full control over your projects.</p>
        </div>
        <div class="steps-grid">
            <div class="step-card">
                <div class="step-number">1</div>
                <h4>Sign Up</h4>
                <p>Create an account in a couple of seconds — no credit card needed.</p>
            </div>
            <div class="step-card">
                <div class="step-number">2</div>
                <h4>Create a Project</h4>
                <p>Enter the title, description and deadline — and start working.</p>
            </div>
            <div class="step-card">
                <div class="step-number">3</div>
                <h4>Add Tasks</h4>
                <p>Break down the project into tasks, set priorities and assign workers.</p>
            </div>
            <div class="step-card">
                <div class="step-number">4</div>
                <h4>Track Progress</h4>
                <p>Monitor progress in real-time and deliver projects on schedule.</p>
            </div>
        </div>
    </section>

    <!-- ════════════ CTA ════════════ -->
    <section class="cta-section">
        <div class="cta-card">
            <h2>Ready to Get Started?</h2>
