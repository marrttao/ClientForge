@page "/Projects/Create"
@model ClientForge.Features.Project.Pages.Create

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ClientForge — Create Project</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <style>
        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
            color: #fff;
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
        }

        .orb {
            position: fixed;
            border-radius: 50%;
            filter: blur(100px);
            opacity: 0.3;
            pointer-events: none;
            z-index: 0;
        }
        .orb-1 { width: 500px; height: 500px; background: #6c63ff; top: -120px; left: -120px; animation: orbFloat1 10s ease-in-out infinite; }
        .orb-2 { width: 400px; height: 400px; background: #ff6584; bottom: -100px; right: -100px; animation: orbFloat2 12s ease-in-out infinite; }
        .orb-3 { width: 300px; height: 300px; background: #43e97b; top: 50%; left: 60%; animation: orbFloat3 14s ease-in-out infinite; }

        @@keyframes orbFloat1 { 0%, 100% { transform: translate(0,0) scale(1); } 50% { transform: translate(40px,30px) scale(1.08); } }
        @@keyframes orbFloat2 { 0%, 100% { transform: translate(0,0) scale(1); } 50% { transform: translate(-30px,-40px) scale(1.06); } }
        @@keyframes orbFloat3 { 0%, 100% { transform: translate(0,0) scale(1); } 50% { transform: translate(-50px,20px) scale(1.1); } }

        .header {
            position: fixed; top: 0; left: 0; right: 0; z-index: 100;
            padding: 0 40px; height: 72px;
            display: flex; align-items: center; justify-content: space-between;
            background: rgba(15, 12, 41, 0.6);
            backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }
        .header-logo { display: flex; align-items: center; gap: 12px; text-decoration: none; }
        .header-logo-icon {
            width: 38px; height: 38px;
            background: linear-gradient(135deg, #6c63ff, #ff6584);
            border-radius: 10px; display: flex; align-items: center; justify-content: center;
            box-shadow: 0 4px 16px rgba(108, 99, 255, 0.3);
        }
        .header-logo-icon i { font-size: 18px; color: #fff; }
        .header-logo-text { font-size: 20px; font-weight: 700; color: #fff; letter-spacing: -0.3px; }
        .header-actions { display: flex; align-items: center; gap: 12px; }
        .btn-ghost {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 10px 22px; border: 1px solid rgba(255,255,255,0.2);
            border-radius: 12px; background: transparent; color: #fff;
            font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 500;
            cursor: pointer; text-decoration: none; transition: all 0.3s ease;
        }
        .btn-ghost:hover { border-color: rgba(255,255,255,0.4); background: rgba(255,255,255,0.06); }

        .content {
            position: relative; z-index: 1;
            padding: 120px 24px 60px;
            max-width: 640px; margin: 0 auto;
        }

        .page-title { text-align: center; margin-bottom: 40px; }
        .page-title-badge {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 8px 18px; background: rgba(108,99,255,0.15);
            border: 1px solid rgba(108,99,255,0.3); border-radius: 50px;
            color: #a8a3ff; font-size: 13px; font-weight: 500; margin-bottom: 20px;
        }
        .page-title h1 { font-size: 36px; font-weight: 800; letter-spacing: -1.2px; margin-bottom: 12px; }
        .page-title h1 .gradient-text {
            background: linear-gradient(135deg, #6c63ff, #ff6584);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .page-title p { font-size: 15px; color: rgba(255,255,255,0.5); }

        .form-card {
            background: rgba(255,255,255,0.06);
            backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 20px; padding: 36px;
        }
        .form-group { margin-bottom: 24px; }
        .form-group label {
            display: block; font-size: 13px; font-weight: 600;
            color: rgba(255,255,255,0.5); margin-bottom: 8px;
        }
        .form-group input, .form-group textarea {
            width: 100%; padding: 12px 16px; border-radius: 12px;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.12);
            color: #fff; font-size: 14px; font-family: 'Inter', sans-serif; outline: none;
            transition: border-color 0.3s;
        }
        .form-group textarea { min-height: 100px; resize: vertical; }
        .form-group input:focus, .form-group textarea:focus { border-color: rgba(108,99,255,0.5); }
        .form-group input::placeholder, .form-group textarea::placeholder { color: rgba(255,255,255,0.25); }

        .text-danger { color: #ef4444; font-size: 12px; margin-top: 4px; }

        .btn-submit {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 14px 32px; border-radius: 14px; border: none;
            background: linear-gradient(135deg, #6c63ff, #5a52d5);
            color: #fff; font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 600;
            cursor: pointer; transition: all 0.3s ease; width: 100%; justify-content: center;
        }
        .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(108,99,255,0.35); }

        .success-message {
            background: rgba(67,233,123,0.12); border: 1px solid rgba(67,233,123,0.3);
            border-radius: 14px; padding: 18px 24px;
            display: flex; align-items: center; gap: 12px;
            margin-bottom: 28px; animation: fadeIn 0.4s ease;
        }
        .success-message i { font-size: 22px; color: #43e97b; }
        .success-message span { font-size: 14px; color: rgba(255,255,255,0.85); line-height: 1.5; }

        .info-note {
            background: rgba(108,99,255,0.08); border: 1px solid rgba(108,99,255,0.2);
            border-radius: 12px; padding: 14px 18px; margin-bottom: 28px;
            display: flex; align-items: flex-start; gap: 10px;
        }
        .info-note i { color: #6c63ff; font-size: 16px; margin-top: 2px; }
        .info-note span { font-size: 13px; color: rgba(255,255,255,0.55); line-height: 1.6; }

        @@keyframes fadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>

<div class="orb orb-1"></div>
<div class="orb orb-2"></div>
<div class="orb orb-3"></div>

<header class="header">
    <a class="header-logo" href="/">
        <div class="header-logo-icon"><i class="fa-solid fa-hammer"></i></div>
        <span class="header-logo-text">ClientForge</span>
    </a>
    <div class="header-actions">
        <a class="btn-ghost" href="/Projects"><i class="fa-solid fa-arrow-left"></i> My Projects</a>
    </div>
</header>

<div class="content">
    <div class="page-title">
        <div class="page-title-badge">
            <i class="fa-solid fa-folder-plus"></i> New Project
        </div>
        <h1>Create a <span class="gradient-text">project</span></h1>
        <p>Fill out the form and submit your project for review.</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="success-message">
            <i class="fa-solid fa-circle-check"></i>
            <span>@Model.SuccessMessage</span>
        </div>
    }

    <div class="form-card">
        <div class="info-note">
            <i class="fa-solid fa-info-circle"></i>
            <span>After submitting the form, your project will be sent to the administrator for review. You will see it in your projects list with status "Pending Review".</span>
        </div>

        <div asp-validation-summary="All" class="text-danger" style="margin-bottom:16px;"></div>

        <form method="post">
            <div class="form-group">
                <label asp-for="Input.Name"><i class="fa-solid fa-heading" style="margin-right:4px;"></i> Project Name</label>
                <input asp-for="Input.Name" placeholder="For example: Website Development" />
                <span asp-validation-for="Input.Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Input.Description"><i class="fa-solid fa-align-left" style="margin-right:4px;"></i> Description</label>
                <textarea asp-for="Input.Description" placeholder="Describe the essence of the project..."></textarea>
                <span asp-validation-for="Input.Description" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Input.DueDate"><i class="fa-solid fa-calendar" style="margin-right:4px;"></i> Desired Deadline</label>
                <input asp-for="Input.DueDate" type="date" />
            </div>
            <button type="submit" class="btn-submit">
                <i class="fa-solid fa-paper-plane"></i> Submit for Review
            </button>
        </form>
    </div>
</div>

</body>
</html>

