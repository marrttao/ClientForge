@page "/Admin/Users"
@model ClientForge.Features.Admin.Pages.Users.Index
@{
    ViewData["Title"] = "Пользователи — Админ";
}

<style>
    .admin-page-header { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; margin-bottom: 24px; }
    .admin-page-title { font-size: 28px; font-weight: 800; }
    .admin-btn {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 10px 22px; border-radius: 12px; font-size: 13px; font-weight: 600;
        text-decoration: none; transition: all .3s ease; cursor: pointer; border: none;
    }
    .admin-btn-primary { background: linear-gradient(135deg, #6c63ff, #5a52d5); color: #fff; }
    .admin-btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(108,99,255,.3); color: #fff; }
    .admin-btn-danger { background: rgba(239,68,68,.15); color: #ef4444; border: 1px solid rgba(239,68,68,.2); }
    .admin-btn-danger:hover { background: rgba(239,68,68,.25); }
    .admin-btn-edit { background: rgba(108,99,255,.12); color: #6c63ff; border: 1px solid rgba(108,99,255,.2); }
    .admin-btn-edit:hover { background: rgba(108,99,255,.22); }
    .admin-btn-sm { padding: 6px 14px; font-size: 12px; border-radius: 8px; }
    .search-box {
        background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.12);
        border-radius: 12px; padding: 10px 16px; color: #fff; font-size: 14px;
        width: 300px; outline: none; font-family: 'Inter', sans-serif;
    }
    .search-box::placeholder { color: rgba(255,255,255,.3); }
    .search-box:focus { border-color: rgba(108,99,255,.5); }
    .admin-table-wrap {
        background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08);
        border-radius: 16px; overflow: hidden;
    }
    .admin-table { width: 100%; border-collapse: collapse; }
    .admin-table thead { background: rgba(255,255,255,.06); }
    .admin-table th { padding: 14px 16px; font-size: 12px; font-weight: 600; color: rgba(255,255,255,.4); text-transform: uppercase; letter-spacing: .5px; text-align: left; }
    .admin-table td { padding: 14px 16px; font-size: 14px; border-top: 1px solid rgba(255,255,255,.05); color: rgba(255,255,255,.8); }
    .admin-table tr:hover td { background: rgba(255,255,255,.03); }
    .role-badge { padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 700; text-transform: uppercase; }
    .role-admin { background: rgba(108,99,255,.2); color: #a78bfa; }
    .role-user { background: rgba(56,189,248,.2); color: #38bdf8; }
    .role-guest { background: rgba(255,255,255,.1); color: rgba(255,255,255,.5); }
    .actions-cell { display: flex; gap: 6px; }
    .back-link { color: rgba(255,255,255,.4); text-decoration: none; font-size: 13px; margin-bottom: 16px; display: inline-block; }
    .back-link:hover { color: #6c63ff; }
</style>

<a href="/Admin" class="back-link"><i class="fa-solid fa-arrow-left"></i> Назад к панели</a>

@if (TempData["ErrorMessage"] != null)
{
    <div style="background: rgba(239,68,68,.15); border: 1px solid rgba(239,68,68,.3); border-radius: 12px; padding: 14px 20px; margin-bottom: 16px; color: #ef4444; font-size: 14px;">
        <i class="fa-solid fa-circle-exclamation" style="margin-right: 8px;"></i>@TempData["ErrorMessage"]
    </div>
}

<div class="admin-page-header">
    <h1 class="admin-page-title"><i class="fa-solid fa-users" style="margin-right:8px; opacity:.6"></i>Пользователи</h1>
    <div style="display:flex; gap:12px; align-items:center;">
        <form method="get" style="display:flex; gap:8px;">
            <input type="text" name="Search" value="@Model.Search" placeholder="Поиск..." class="search-box" />
            <button type="submit" class="admin-btn admin-btn-primary admin-btn-sm"><i class="fa-solid fa-search"></i></button>
        </form>
        <a href="/Admin/Users/Create" class="admin-btn admin-btn-primary"><i class="fa-solid fa-plus"></i> Добавить</a>
    </div>
</div>

<div class="admin-table-wrap">
    <table class="admin-table">
        <thead>
            <tr>
                <th>Логин</th>
                <th>Имя</th>
                <th>Фамилия</th>
                <th>Email</th>
                <th>Роль</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td style="font-weight:600;">@user.Login</td>
                    <td>@user.Name</td>
                    <td>@user.Surname</td>
                    <td>@user.Email</td>
                    <td>
                        <span class="role-badge role-@user.Role.ToString()">@user.Role</span>
                    </td>
                    <td>
                        <div class="actions-cell">
                            <a href="/Admin/Users/Edit/@user.Id" class="admin-btn admin-btn-edit admin-btn-sm"><i class="fa-solid fa-pen"></i></a>
                            <form method="post" asp-page-handler="Delete" style="display:inline;">
                                <input type="hidden" name="id" value="@user.Id" />
                                <button type="submit" class="admin-btn admin-btn-danger admin-btn-sm" onclick="return confirm('Удалить пользователя @user.Login?')"><i class="fa-solid fa-trash"></i></button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Users.Any())
            {
                <tr><td colspan="6" style="text-align:center; color:rgba(255,255,255,.3); padding:40px;">Пользователей не найдено</td></tr>
            }
        </tbody>
    </table>
</div>

