@page "/Admin/Projects/Create"
@model ClientForge.Features.Admin.Pages.Projects.Create
@using ClientForge.Features.Project.Models
@{
    ViewData["Title"] = "Create Project — Admin";
}

<style>
    .admin-form-card {
        background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1);
        border-radius: 16px; padding: 32px; max-width: 600px; backdrop-filter: blur(10px);
    }
    .admin-form-title { font-size: 24px; font-weight: 800; margin-bottom: 24px; }
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; font-size: 13px; font-weight: 600; color: rgba(255,255,255,.5); margin-bottom: 6px; }
    .form-group input, .form-group select, .form-group textarea {
        width: 100%; padding: 10px 14px; border-radius: 10px;
        background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.12);
        color: #fff; font-size: 14px; font-family: 'Inter', sans-serif; outline: none;
    }
    .form-group textarea { min-height: 80px; resize: vertical; }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: rgba(108,99,255,.5); }
    .form-group select option { background: #1a1a2e; color: #fff; }
    .admin-btn {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 10px 22px; border-radius: 12px; font-size: 13px; font-weight: 600;
        text-decoration: none; transition: all .3s ease; cursor: pointer; border: none;
    }
    .admin-btn-primary { background: linear-gradient(135deg, #6c63ff, #5a52d5); color: #fff; }
    .admin-btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(108,99,255,.3); }
    .admin-btn-secondary { background: rgba(255,255,255,.08); color: rgba(255,255,255,.6); border: 1px solid rgba(255,255,255,.12); }
    .back-link { color: rgba(255,255,255,.4); text-decoration: none; font-size: 13px; margin-bottom: 16px; display: inline-block; }
    .back-link:hover { color: #6c63ff; }
    .text-danger { color: #ef4444; font-size: 12px; }
</style>

<a href="/Admin/Projects" class="back-link"><i class="fa-solid fa-arrow-left"></i> Back to Projects</a>

<div class="admin-form-card">
    <h2 class="admin-form-title"><i class="fa-solid fa-folder-plus" style="margin-right:8px; opacity:.6"></i>Create Project</h2>

    <div asp-validation-summary="All" class="text-danger" style="margin-bottom:16px;"></div>

    <form method="post">
        <div class="form-group">
            <label asp-for="Input.Name">Name</label>
            <input asp-for="Input.Name" placeholder="Project name" />
            <span asp-validation-for="Input.Name" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Input.Description">Description</label>
            <textarea asp-for="Input.Description" placeholder="Project description"></textarea>
        </div>
        <div class="form-group">
            <label asp-for="Input.Status">Status</label>
            <select asp-for="Input.Status" asp-items="Html.GetEnumSelectList<ProjectStatus>()"></select>
        </div>
        <div class="form-group">
            <label asp-for="Input.DueDate">Deadline</label>
            <input asp-for="Input.DueDate" type="date" />
        </div>
        <div class="form-group">
            <label asp-for="Input.ClientId">Client</label>
            <select asp-for="Input.ClientId" asp-items="Model.ClientList">
                <option value="">— Select a Client —</option>
            </select>
            <span asp-validation-for="Input.ClientId" class="text-danger"></span>
        </div>
        <div style="display:flex; gap:12px; margin-top:24px;">
            <button type="submit" class="admin-btn admin-btn-primary"><i class="fa-solid fa-check"></i> Create</button>
            <a href="/Admin/Projects" class="admin-btn admin-btn-secondary">Cancel</a>
        </div>
    </form>
</div>

